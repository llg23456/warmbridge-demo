# =============================================================================
# 暖桥服务端环境变量（复制本文件为 .env 后填写真实值）
# 对照文档：《vivo-aigc-接口开发速查.md》
# =============================================================================
# 切勿将 .env 提交到 Git 或对外泄露。

# -----------------------------------------------------------------------------
# §2 鉴权 — 所有云端 API 请求头：Authorization: Bearer <AppKey>
# 在 AIGC 官网「应用赛道参赛资源」等处获取，替换下面的占位符。
# -----------------------------------------------------------------------------
VIVO_APP_KEY=your_AppKey_here

# -----------------------------------------------------------------------------
# §3 大模型对话（OpenAI 兼容 Chat Completions）
# 本 Demo 的 /api/explain 仅使用此项；request_id 由代码自动生成并作为 Query 传入。
# -----------------------------------------------------------------------------
# 接口地址（一般无需改，与文档一致）
VIVO_CHAT_URL=https://api-ai.vivo.com.cn/v1/chat/completions

# 模型名（须与账号已开通权限一致，文档可选示例如下，任选其一）
#   Volc-DeepSeek-V3.2
#   Doubao-Seed-2.0-mini / Doubao-Seed-2.0-lite / Doubao-Seed-2.0-pro
#   qwen3.5-plus
VIVO_CHAT_MODEL=Doubao-Seed-2.0-mini

# -----------------------------------------------------------------------------
# §8 通用 OCR（/api/image/explain）
# -----------------------------------------------------------------------------
# businessid 从哪里找？
#   ① 本仓库《vivo-aigc-接口开发速查.md》§8 表格「businessid 补充说明」中的两个固定串，
#      是官方文档摘录的示例值，不是随机编的；但赛事/控制台若更新策略，以官网最新说明为准。
#   ② vivo AIGC 控制台：应用 / 能力管理中与「通用 OCR」相关的参数说明、或下载的最新接入 PDF。
#   ③ 两个示例（二选一，与当前账号开通的识别策略一致）：
#        1990173156ceb8a09eee80c293135279  （文档写明：支持旋转图、非正向文字）
#        8bf312e702043779ad0f2760b37a0806  （文档写明：仅正向文字，相对更快）
#   若填错或未开通 OCR，接口会返回 OCR 业务错误而非「图片格式错误」；
#   App 端须用 multipart 字段 file 上传真实二进制（见 README / 排查清单）。
VIVO_OCR_BUSINESSID=
# 与上一行等价别名（防 .env 键名写错）
# VIVO_OCR_BUSINESS_ID=
# 识别不到字时可试：VIVO_OCR_POS=2
# VIVO_OCR_POS=0
# 文档示例为 HTTP；若需 HTTPS 可改（以官网为准）
# VIVO_OCR_URL=http://api-ai.vivo.com.cn/ocr/general_recognition

# -----------------------------------------------------------------------------
# §14 TTS（/api/tts，长音频朗读，WebSocket）
# -----------------------------------------------------------------------------
# 若 uvicorn 日志出现「WebSocket connection: HTTP 400」：
#   ① 代码已带文档要求的 X-AI-GATEWAY-SIGNATURE: developers-aigc（缺此头易直接 400）；
#   ② 已默认关闭 permessage-deflate（compression）；
#   ③ vaid：未配置时与官方 tts_examples 一致使用 123456789；勿把 VIVO_APP_ID 当 vaid；
# VIVO_TTS_VAID=123456789
# VIVO_TTS_ENGINEID=long_audio_synthesis_screen
# VIVO_TTS_VCN=x2_yige_news

# 未配置 VIVO_APP_KEY 时：/api/explain 返回本地占位解读，便于无密钥先联调 App UI。

# -----------------------------------------------------------------------------
# 分享解读辅助：DuckDuckGo Instant Answer（无需 Key；部署环境屏蔽外网时可关）
# -----------------------------------------------------------------------------
# WEB_SEARCH_ENABLED=true
